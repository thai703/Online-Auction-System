# Copy this to .env and fill in your values
# NEVER commit .env to git

# Database
DB_URL=jdbc:mysql://localhost:3306/auctions?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=auction_app
DB_PASSWORD=your_db_password

# JWT - generate a strong random secret
JWT_SECRET=ChangeThisToASecureRandomSecretKeyInProduction2024
JWT_EXPIRATION=86400000

# Email
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Server
SERVER_PORT=8123
SERVER_URL=https://your-domain.com

# Upload
UPLOAD_PATH=/data/auction-images

# Admin bootstrap (set to true only for first run, then disable)
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_EMAIL=admin@auctions.local
ADMIN_PASSWORD=YourStrongAdminPassword123!

# WebSocket
WEBSOCKET_ALLOWED_ORIGINS=https://your-domain.com

# JPA
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false
THYMELEAF_CACHE=true
FLYWAY_ENABLED=true

# Verification
VERIFICATION_ENABLED=true

# Docker Compose specific
DB_ROOT_PASSWORD=your_mysql_root_password
APP_PORT=8123
